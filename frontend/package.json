{
  "name": "luxe-barber",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cd ../backend && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "server:dev": "cd ../backend && python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.0",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^6.2.0"
  }
}
