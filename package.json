{
  "name": "luxe-barber-fullstack",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd frontend && npm install",
    "build": "cd frontend && npm run build",
    "dev": "cd frontend && npm run dev",
    "server": "cd backend && python -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "server:dev": "cd backend && python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "init-db": "cd backend && python init_db.py",
    "seed": "cd backend && python seed_data.py",
    "setup": "npm run install-all && npm run init-db && npm run seed && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
